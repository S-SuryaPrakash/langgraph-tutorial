    "from dotenv import load_dotenv\n",
    "import os\n",
    "load_dotenv()\n",
    "if os.environ[\"GOOGLE_API_KEY\"]==\"\" :\n",
    "    raise ValueError(\"Please set the GOOGLE_API_KEY environment variable in the .env file.\")\n",
    "else:\n",
    "    print(\"GOOGLE_API_KEY is set.\")"
